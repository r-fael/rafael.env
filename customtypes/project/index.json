{
  "id": "project",
  "label": "Project",
  "repeatable": true,
  "status": true,
  "format": "page",
  "json": {
    "Main": {
      "uid": {
        "type": "UID",
        "config": {
          "label": "UID",
          "placeholder": "url-slug-for-the-project"
        }
      },
      "title": {
        "type": "Text",
        "config": {
          "label": "Title",
          "placeholder": "Project title"
        }
      },
      "description": {
        "type": "Text",
        "config": {
          "label": "Description",
          "placeholder": "Short summary shown on the card"
        }
      },
      "image": {
        "type": "Image",
        "config": {
          "label": "Thumbnail",
          "constraint": {
            "width": 1200,
            "height": 630
          },
          "thumbnails": []
        }
      },
      "tags": {
        "type": "Group",
        "config": {
          "label": "Tech tags",
          "fields": {
            "label": {
              "type": "Text",
              "config": {
                "label": "Label",
                "placeholder": "e.g. Next.js"
              }
            }
          }
        }
      },
      "live_url": {
        "type": "Link",
        "config": {
          "label": "Live URL",
          "placeholder": "https://example.com",
          "select": "web",
          "allowText": false
        }
      },
      "github_url": {
        "type": "Link",
        "config": {
          "label": "GitHub URL",
          "placeholder": "https://github.com/...",
          "select": "web",
          "allowText": false
        }
      },
      "slices": {
        "type": "Slices",
        "fieldset": "Slice Zone"
      }
    }
  }
}
